<Window x:Class="MacroPilot.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MacroPilot.Core.Models;assembly=MacroPilot.Core"
        xmlns:playback="clr-namespace:MacroPilot.Core.Playback;assembly=MacroPilot.Core"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MacroPilot WPF"
        Height="760"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FA"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <ObjectDataProvider x:Key="ActionTypes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:MacroActionType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="MouseButtons" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:MouseButtonKind" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DCE5EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style x:Key="FieldPanelStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="MinWidth" Value="108" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#587083" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CAD6E2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#102033" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#00758E" />
            <Setter Property="BorderBrush" Value="#00758E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFF5F6" />
            <Setter Property="BorderBrush" Value="#F0B8BE" />
            <Setter Property="Foreground" Value="#8F2632" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#CAD6E2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="6,3" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DCE5EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E8EEF5" />
            <Setter Property="RowHeaderWidth" Value="36" />
            <Setter Property="AlternatingRowBackground" Value="#F8FBFE" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,8">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="NewButton" Content="Новый" Click="NewButton_Click" />
                    <Button x:Name="OpenButton" Content="Открыть" Click="OpenButton_Click" />
                    <Button x:Name="SaveButton" Content="Сохранить" Click="SaveButton_Click" />
                    <Button x:Name="ClearButton" Content="Очистить" Style="{StaticResource DangerButtonStyle}" Click="ClearButton_Click" />
                    <Separator Width="10" Visibility="Hidden" />
                    <Button x:Name="RecordButton" Content="Запись" Style="{StaticResource PrimaryButtonStyle}" Click="RecordButton_Click" />
                    <Button x:Name="StopButton" Content="Стоп" Click="StopButton_Click" />
                    <Button x:Name="PlayButton" Content="Пуск" Style="{StaticResource PrimaryButtonStyle}" Click="PlayButton_Click" />
                    <Separator Width="10" Visibility="Hidden" />
                    <Button x:Name="AddDelayButton" Content="+ Пауза" Click="AddDelayButton_Click" />
                    <Button x:Name="DeleteButton" Content="Удалить строки" Click="DeleteButton_Click" />
                    <Button x:Name="MoveUpButton" Content="Выше" Click="MoveUpButton_Click" />
                    <Button x:Name="MoveDownButton" Content="Ниже" Click="MoveDownButton_Click" />
                </StackPanel>

                <WrapPanel DockPanel.Dock="Top" VerticalAlignment="Top">
                    <StackPanel Style="{StaticResource FieldPanelStyle}" Width="230">
                        <TextBlock Text="Имя сценария" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="NameTextBox" Text="Мой макрос" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource FieldPanelStyle}" Width="120">
                        <TextBlock Text="Режим" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="RepeatModeComboBox" SelectionChanged="RepeatModeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Повторы" Tag="{x:Static playback:PlaybackRepeatMode.Count}" IsSelected="True" />
                            <ComboBoxItem Content="Минуты" Tag="{x:Static playback:PlaybackRepeatMode.Duration}" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel x:Name="RepeatCountPanel" Style="{StaticResource FieldPanelStyle}" Width="108">
                        <TextBlock Text="Повторы" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="RepeatCountTextBox" Text="1" TextChanged="PlaybackSettingsChanged" />
                    </StackPanel>

                    <StackPanel x:Name="DurationPanel" Style="{StaticResource FieldPanelStyle}" Width="132" Visibility="Collapsed">
                        <TextBlock Text="Длительность, мин" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="DurationMinutesTextBox" Text="60" TextChanged="PlaybackSettingsChanged" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource FieldPanelStyle}" Width="108">
                        <TextBlock Text="Скорость" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="SpeedTextBox" Text="1.0" TextChanged="PlaybackSettingsChanged" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource FieldPanelStyle}" Width="108">
                        <TextBlock Text="Старт, сек" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="StartDelayTextBox" Text="1.5" TextChanged="PlaybackSettingsChanged" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource FieldPanelStyle}" MinWidth="140" Margin="0,18,12,0">
                        <CheckBox x:Name="CaptureMovesCheckBox" Content="движения мыши" Margin="0,0,0,5" />
                        <CheckBox x:Name="MoveCursorCheckBox" Content="ставить курсор" IsChecked="True" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource FieldPanelStyle}" MinWidth="190" Margin="0,1,12,0">
                        <TextBlock Text="Сценарий" Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock x:Name="ScriptDurationTextBlock" Text="00:00.0" FontWeight="SemiBold" Foreground="#102033" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource FieldPanelStyle}" MinWidth="190" Margin="0,1,12,0">
                        <TextBlock Text="План запуска" Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock x:Name="RunPlanTextBlock" Text="1 повтор" FontWeight="SemiBold" Foreground="#102033" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource FieldPanelStyle}" MinWidth="170" Margin="0,1,0,0">
                        <TextBlock Text="Осталось" Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock x:Name="RemainingTextBlock" Text="--:--" FontWeight="SemiBold" Foreground="#00758E" />
                    </StackPanel>
                </WrapPanel>

                <TextBlock DockPanel.Dock="Bottom"
                           Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="#587083"
                           Text="Ctrl+F9 запускает запись. Shift+F9 останавливает запись. Esc останавливает проигрывание." />
            </DockPanel>
        </Border>

        <DataGrid x:Name="ActionsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  SelectionChanged="ActionsGrid_SelectionChanged"
                  CellEditEnding="ActionsGrid_CellEditEnding"
                  CurrentCellChanged="ActionsGrid_CurrentCellChanged">
            <DataGrid.Columns>
                <DataGridComboBoxColumn Header="Тип"
                                        SelectedItemBinding="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{Binding Source={StaticResource ActionTypes}}"
                                        Width="120" />
                <DataGridTextColumn Header="Задержка, мс" Binding="{Binding DelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                <DataGridTextColumn Header="Время" Binding="{Binding DelayText}" IsReadOnly="True" Width="90" />
                <DataGridTextColumn Header="X" Binding="{Binding X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                <DataGridTextColumn Header="Y" Binding="{Binding Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                <DataGridComboBoxColumn Header="Кнопка"
                                        SelectedItemBinding="{Binding Button, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{Binding Source={StaticResource MouseButtons}}"
                                        Width="100" />
                <DataGridTextColumn Header="Колесо" Binding="{Binding Delta, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                <DataGridTextColumn Header="VK" Binding="{Binding VirtualKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                <DataGridTextColumn Header="Клавиша" Binding="{Binding KeyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2"
                Background="#102033"
                CornerRadius="6"
                Padding="12,8"
                Margin="0,8,0,0">
            <TextBlock x:Name="StatusTextBlock" Foreground="White" Text="Готово" />
        </Border>
    </Grid>
</Window>
