<Window x:Class="MacroPilot.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MacroPilot.Core.Models;assembly=MacroPilot.Core"
        xmlns:playback="clr-namespace:MacroPilot.Core.Playback;assembly=MacroPilot.Core"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MacroPilot WPF"
        Height="760"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FA"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <ObjectDataProvider x:Key="ActionTypes"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:MacroActionType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="MouseButtons"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:MouseButtonKind" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DCE5EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CAD6E2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#102033" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#00758E" />
            <Setter Property="BorderBrush" Value="#00758E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#CAD6E2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="6,3" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DCE5EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E8EEF5" />
            <Setter Property="RowHeaderWidth" Value="36" />
            <Setter Property="AlternatingRowBackground" Value="#F8FBFE" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Button x:Name="NewButton" Content="Новый" Click="NewButton_Click" />
                        <Button x:Name="OpenButton" Content="Открыть" Click="OpenButton_Click" />
                        <Button x:Name="SaveButton" Content="Сохранить" Click="SaveButton_Click" />
                        <Separator Width="10" Visibility="Hidden" />
                        <Button x:Name="RecordButton" Content="Запись" Style="{StaticResource PrimaryButtonStyle}" Click="RecordButton_Click" />
                        <Button x:Name="StopButton" Content="Стоп" Click="StopButton_Click" />
                        <Button x:Name="PlayButton" Content="Пуск" Style="{StaticResource PrimaryButtonStyle}" Click="PlayButton_Click" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="AddDelayButton" Content="+ Пауза" Click="AddDelayButton_Click" />
                        <Button x:Name="DeleteButton" Content="Удалить" Click="DeleteButton_Click" />
                        <Button x:Name="MoveUpButton" Content="Выше" Click="MoveUpButton_Click" />
                        <Button x:Name="MoveDownButton" Content="Ниже" Click="MoveDownButton_Click" Margin="0" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Имя сценария" FontSize="12" Foreground="#587083" Margin="0,0,0,4" />
                        <TextBox x:Name="NameTextBox" Text="Мой макрос" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Режим" FontSize="12" Foreground="#587083" Margin="0,0,0,4" />
                        <ComboBox x:Name="RepeatModeComboBox" SelectionChanged="RepeatModeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Повторы" Tag="{x:Static playback:PlaybackRepeatMode.Count}" IsSelected="True" />
                            <ComboBoxItem Content="Минуты" Tag="{x:Static playback:PlaybackRepeatMode.Duration}" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="12,0,0,0">
                        <TextBlock Text="Повторы" FontSize="12" Foreground="#587083" Margin="0,0,0,4" />
                        <TextBox x:Name="RepeatCountTextBox" Text="1" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="12,0,0,0">
                        <TextBlock Text="Длительность, мин" FontSize="12" Foreground="#587083" Margin="0,0,0,4" />
                        <TextBox x:Name="DurationMinutesTextBox" Text="60" IsEnabled="False" />
                    </StackPanel>

                    <StackPanel Grid.Column="4" Margin="12,0,0,0">
                        <TextBlock Text="Скорость" FontSize="12" Foreground="#587083" Margin="0,0,0,4" />
                        <TextBox x:Name="SpeedTextBox" Text="1.0" />
                    </StackPanel>

                    <StackPanel Grid.Column="5" Margin="12,0,0,0">
                        <TextBlock Text="Старт, сек" FontSize="12" Foreground="#587083" Margin="0,0,0,4" />
                        <TextBox x:Name="StartDelayTextBox" Text="1.5" />
                    </StackPanel>

                    <StackPanel Grid.Column="6" Margin="12,19,0,0">
                        <CheckBox x:Name="CaptureMovesCheckBox" Content="движения мыши" Margin="0,0,0,6" />
                        <CheckBox x:Name="MoveCursorCheckBox" Content="ставить курсор" IsChecked="True" />
                    </StackPanel>

                    <TextBlock Grid.Column="7"
                               Margin="18,20,0,0"
                               Foreground="#587083"
                               TextWrapping="Wrap"
                               Text="Ctrl+Alt+F8 запускает запись. F9 останавливает запись. Esc останавливает проигрывание, когда окно активно." />
                </Grid>
            </Grid>
        </Border>

        <DataGrid x:Name="ActionsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  SelectionChanged="ActionsGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridComboBoxColumn Header="Тип"
                                        SelectedItemBinding="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{Binding Source={StaticResource ActionTypes}}"
                                        Width="120" />
                <DataGridTextColumn Header="Задержка, мс" Binding="{Binding DelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                <DataGridTextColumn Header="X" Binding="{Binding X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                <DataGridTextColumn Header="Y" Binding="{Binding Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                <DataGridComboBoxColumn Header="Кнопка"
                                        SelectedItemBinding="{Binding Button, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{Binding Source={StaticResource MouseButtons}}"
                                        Width="100" />
                <DataGridTextColumn Header="Колесо" Binding="{Binding Delta, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                <DataGridTextColumn Header="VK" Binding="{Binding VirtualKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                <DataGridTextColumn Header="Клавиша" Binding="{Binding KeyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2"
                Background="#102033"
                CornerRadius="6"
                Padding="12,8"
                Margin="0,12,0,0">
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="White"
                       Text="Готово" />
        </Border>
    </Grid>
</Window>
